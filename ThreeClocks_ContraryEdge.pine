// ════════════════════════════════════════════════════════════
//  THE 3 CLOCKS — Contrarian Edge System  |  Pine Script v5
// ════════════════════════════════════════════════════════════
//
//  PHILOSOPHY:
//  Markets are not random — they are auctions driven by
//  imbalance between buyers and sellers. The edge is not
//  in predicting direction, it's in finding HIGH PROBABILITY,
//  HIGH REWARD setups and sizing risk correctly.
//
//  THE CORE INSIGHT:
//  When everyone sees the same trade (obvious breakout),
//  and they all enter at the same time, the fuel is SPENT.
//  Smart money uses that retail breakout to EXIT, not enter.
//  Price snaps back. Retail is trapped. We ride the snap.
//
//  THE 3 CLOCKS:
//  ─────────────────────────────────────────────────────────
//
//  CLOCK 1 — MARKET CLOCK (Volatility)
//  Markets breathe: compression → expansion → compression
//  Compression = energy building = coiling spring
//  You want to be ready BEFORE the spring uncoils.
//  Signal: ATR well below its average + Bollinger Band squeeze
//
//  CLOCK 2 — INSTITUTIONAL CLOCK (Session / Time)
//  Price moves are NOT equal across all hours.
//  London Open (07:00–10:00 UTC) and NY Open (13:00–16:00 UTC)
//  are when REAL institutional volume enters the market.
//  Outside these windows = noise. Inside = signal.
//  Rule: Only trade when institutions are active.
//
//  CLOCK 3 — PSYCHOLOGICAL CLOCK (Consensus / Fakeout)
//  When retail traders all see the same breakout and pile in,
//  the obvious trade becomes the TRAP. A candle that breaks
//  above/below a range high/low but CLOSES back inside is
//  the fingerprint of a fakeout — trapped retail, incoming reversal.
//  Signal: Wick beyond range, body closes inside. Fade it.
//
//  THE TRADE:
//  ─────────────────────────────────────────────────────────
//  All 3 clocks aligned = Maximum EV (Expected Value)
//  2 clocks aligned     = Acceptable setup
//  1 clock              = Ignore
//
//  Entry:   On fakeout candle close (Clock 3 fires)
//  Stop:    Beyond the wick (where the trap was set)
//  Target:  ATR × multiplier (minimum 1:3 R:R, ideal 1:5)
//  Filter:  Volatility compressed (Clock 1) + In session (Clock 2)
//
// ════════════════════════════════════════════════════════════

//@version=5
indicator("The 3 Clocks - Contrarian Edge", shorttitle="3C-Edge", overlay=true, max_boxes_count=200, max_lines_count=200, max_labels_count=200)

// ────────────────────────────────────────────────────────────
//  INPUTS
// ────────────────────────────────────────────────────────────

// Clock 1: Volatility / Market Breath
i_atr_len    = input.int(14,    "ATR Length",               minval=5, maxval=30,  group="Clock 1: Market (Volatility)")
i_atr_avg    = input.int(50,    "ATR Average (baseline)",   minval=20, maxval=200, group="Clock 1: Market (Volatility)")
i_compress   = input.float(0.75,"Compression Threshold",    minval=0.3, maxval=1.0, step=0.05, group="Clock 1: Market (Volatility)", tooltip="ATR/Avg ATR ratio. Below this = market is coiling. 0.75 = 25% below average.")
i_bb_len     = input.int(20,    "Bollinger Band Length",    minval=10, maxval=50,  group="Clock 1: Market (Volatility)")
i_bb_mult    = input.float(2.0, "BB Multiplier",            minval=1.0, maxval=4.0, step=0.1, group="Clock 1: Market (Volatility)")

// Clock 2: Institutional / Session
i_london_on  = input.bool(true,  "London Open (07:00-10:00 UTC)", group="Clock 2: Institutional (Session)")
i_ny_on      = input.bool(true,  "NY Open (13:00-16:00 UTC)",     group="Clock 2: Institutional (Session)")
i_show_sess  = input.bool(true,  "Highlight Sessions on Chart",   group="Clock 2: Institutional (Session)")
i_col_london = input.color(color.new(color.blue,   88), "London Color", group="Clock 2: Institutional (Session)")
i_col_ny     = input.color(color.new(color.orange, 88), "NY Color",     group="Clock 2: Institutional (Session)")

// Clock 3: Psychological / Fakeout
i_fake_len   = input.int(20,    "Range Lookback (bars)",    minval=5, maxval=100, group="Clock 3: Psychological (Fakeout)", tooltip="How many bars to look back for the range high/low that gets faked out.")
i_need_comp  = input.bool(true, "Require Compression (Clock 1)", group="Clock 3: Psychological (Fakeout)")
i_need_sess  = input.bool(true, "Require Session (Clock 2)",     group="Clock 3: Psychological (Fakeout)")

// Risk & Reward
i_sl_atr     = input.float(1.5, "Stop Loss (x ATR)",   minval=0.5, maxval=5.0, step=0.25, group="Risk : Reward")
i_tp_atr     = input.float(4.5, "Take Profit (x ATR)", minval=1.0, maxval=20.0, step=0.5,  group="Risk : Reward")
i_show_rr    = input.bool(true, "Show SL / TP Boxes",  group="Risk : Reward")
i_box_bars   = input.int(40,    "Box Width (bars)",    minval=5, maxval=200,    group="Risk : Reward")

// Display
i_show_table  = input.bool(true, "Show Dashboard",          group="Display")
i_show_labels = input.bool(true, "Show Signal Labels",      group="Display")
i_show_bb     = input.bool(true, "Show Bollinger Bands",    group="Display")
i_show_range  = input.bool(true, "Show Fakeout Range Level",group="Display")

// ────────────────────────────────────────────────────────────
//  CLOCK 1: MARKET (VOLATILITY)
// ────────────────────────────────────────────────────────────

atr_now   = ta.atr(i_atr_len)
atr_avg   = ta.sma(atr_now, i_atr_avg)
atr_ratio = atr_now / atr_avg

compressed    = atr_ratio < i_compress
was_comp_3    = compressed[1] or compressed[2] or compressed[3]
just_expanded = not compressed and was_comp_3

[bb_upper, bb_mid, bb_lower] = ta.bb(close, i_bb_len, i_bb_mult)
bb_width     = (bb_upper - bb_lower) / bb_mid
bb_width_sma = ta.sma(bb_width, i_bb_len)
bb_squeeze   = bb_width < bb_width_sma * 0.8

clock1_ready = compressed or was_comp_3

// ────────────────────────────────────────────────────────────
//  CLOCK 2: INSTITUTIONAL (SESSION)
// ────────────────────────────────────────────────────────────

h = hour(time, "UTC")
london_open = h >= 7  and h < 10
ny_open     = h >= 13 and h < 16
in_session  = (i_london_on and london_open) or (i_ny_on and ny_open)

clock2_ready = in_session

bgcolor(i_show_sess and i_london_on and london_open ? i_col_london : na, title="London Session")
bgcolor(i_show_sess and i_ny_on     and ny_open     ? i_col_ny     : na, title="NY Session")

// ────────────────────────────────────────────────────────────
//  CLOCK 3: PSYCHOLOGICAL (FAKEOUT)
// ────────────────────────────────────────────────────────────
//
//  The range high and low = levels where retail stops cluster
//  A breakout above the range high = retail buys → gets trapped
//  A breakdown below the range low = retail sells → gets trapped
//  When price closes BACK inside the range → the trap is set
//  We fade the trapped retail traders

range_high = ta.highest(high[1], i_fake_len)
range_low  = ta.lowest(low[1],   i_fake_len)

// Bearish Fakeout: wick above range high, close back inside AND bearish candle
fakeout_bear = high > range_high and close < range_high and close < open

// Bullish Fakeout: wick below range low, close back inside AND bullish candle
fakeout_bull = low < range_low and close > range_low and close > open

clock3_bear = fakeout_bear
clock3_bull = fakeout_bull

// ────────────────────────────────────────────────────────────
//  EV SCORE (how many clocks are aligned)
// ────────────────────────────────────────────────────────────

ev_clock1  = clock1_ready ? 1 : 0
ev_clock2  = clock2_ready ? 1 : 0
ev_bear    = ev_clock1 + ev_clock2 + (fakeout_bear ? 1 : 0)
ev_bull    = ev_clock1 + ev_clock2 + (fakeout_bull ? 1 : 0)

// ────────────────────────────────────────────────────────────
//  FINAL SIGNAL CONDITIONS
// ────────────────────────────────────────────────────────────

filter_comp = not i_need_comp or clock1_ready
filter_sess = not i_need_sess or clock2_ready

signal_bear = fakeout_bear and filter_comp and filter_sess
signal_bull = fakeout_bull and filter_comp and filter_sess

// ────────────────────────────────────────────────────────────
//  RANGE LEVELS (visual)
// ────────────────────────────────────────────────────────────

plot(i_show_range ? range_high : na, "Range High", color=color.new(color.red,   60), linewidth=1, style=plot.style_stepline)
plot(i_show_range ? range_low  : na, "Range Low",  color=color.new(color.green, 60), linewidth=1, style=plot.style_stepline)

// ────────────────────────────────────────────────────────────
//  BOLLINGER BANDS
// ────────────────────────────────────────────────────────────

p_bb_up  = plot(i_show_bb ? bb_upper : na, "BB Upper", color=color.new(color.white, 75), linewidth=1)
p_bb_lo  = plot(i_show_bb ? bb_lower : na, "BB Lower", color=color.new(color.white, 75), linewidth=1)
plot(i_show_bb ? bb_mid : na, "BB Mid", color=color.new(color.white, 88), linewidth=1)
fill(p_bb_up, p_bb_lo, color=compressed ? color.new(color.yellow, 93) : na, title="Compression Zone")

// ────────────────────────────────────────────────────────────
//  SIGNAL SHAPES
// ────────────────────────────────────────────────────────────

plotshape(signal_bear, title="Bearish Fakeout", style=shape.triangledown, location=location.abovebar, color=color.red,  size=size.normal, text="FADE")
plotshape(signal_bull, title="Bullish Fakeout", style=shape.triangleup,   location=location.belowbar, color=color.lime, size=size.normal, text="FADE")

// ────────────────────────────────────────────────────────────
//  SL / TP BOXES + LABELS
// ────────────────────────────────────────────────────────────

var box sl_box_b = na
var box tp_box_b = na
var box sl_box_s = na
var box tp_box_s = na

if signal_bear
    entry_b = close
    sl_b    = high + atr_now * i_sl_atr * 0.3
    tp_b    = entry_b - atr_now * i_tp_atr
    rr_b    = math.round(i_tp_atr / i_sl_atr, 1)
    box.delete(sl_box_b)
    box.delete(tp_box_b)
    sl_box_b := box.new(bar_index, sl_b, bar_index + i_box_bars, entry_b, bgcolor=color.new(color.red, 82), border_color=color.new(color.red, 40), border_width=1, text="STOP LOSS", text_color=color.red, text_size=size.tiny)
    tp_box_b := box.new(bar_index, entry_b, bar_index + i_box_bars, tp_b, bgcolor=color.new(color.lime, 82), border_color=color.new(color.lime, 40), border_width=1, text="TARGET  1:" + str.tostring(rr_b), text_color=color.lime, text_size=size.tiny)
    if i_show_labels
        label.new(bar_index, high + atr_now * 0.3, "FADE SHORT  |  EV: " + str.tostring(ev_bear) + "/3  |  RR 1:" + str.tostring(rr_b), color=color.new(color.red, 10), textcolor=color.white, style=label.style_label_down, size=size.small)
    line.new(bar_index - i_fake_len, range_high, bar_index, range_high, color=color.new(color.red, 30), width=2, style=line.style_dashed)

if signal_bull
    entry_s = close
    sl_s    = low - atr_now * i_sl_atr * 0.3
    tp_s    = entry_s + atr_now * i_tp_atr
    rr_s    = math.round(i_tp_atr / i_sl_atr, 1)
    box.delete(sl_box_s)
    box.delete(tp_box_s)
    sl_box_s := box.new(bar_index, entry_s, bar_index + i_box_bars, sl_s, bgcolor=color.new(color.red, 82), border_color=color.new(color.red, 40), border_width=1, text="STOP LOSS", text_color=color.red, text_size=size.tiny)
    tp_box_s := box.new(bar_index, tp_s, bar_index + i_box_bars, entry_s, bgcolor=color.new(color.lime, 82), border_color=color.new(color.lime, 40), border_width=1, text="TARGET  1:" + str.tostring(rr_s), text_color=color.lime, text_size=size.tiny)
    if i_show_labels
        label.new(bar_index, low - atr_now * 0.3, "FADE LONG  |  EV: " + str.tostring(ev_bull) + "/3  |  RR 1:" + str.tostring(rr_s), color=color.new(color.lime, 10), textcolor=color.black, style=label.style_label_up, size=size.small)
    line.new(bar_index - i_fake_len, range_low, bar_index, range_low, color=color.new(color.lime, 30), width=2, style=line.style_dashed)

// ────────────────────────────────────────────────────────────
//  DASHBOARD TABLE
// ────────────────────────────────────────────────────────────

var table dash = table.new(position.top_right, 2, 16, bgcolor=color.new(color.black, 72), border_color=color.new(color.white, 50), border_width=1, frame_color=color.new(color.white, 75), frame_width=1)

if i_show_table and barstate.islast

    // Header
    table.cell(dash, 0, 0, "THE 3 CLOCKS", text_color=color.white, text_size=size.normal, bgcolor=color.new(color.navy, 35))
    table.cell(dash, 1, 0, "EV EDGE",      text_color=color.yellow, text_size=size.small, bgcolor=color.new(color.navy, 35))

    // Clock 1
    c1_str = compressed ? "COILING (energy building)" : just_expanded ? "EXPANDING now" : was_comp_3 ? "Post-compression" : "Normal"
    c1_col = compressed ? color.yellow : just_expanded ? color.lime : was_comp_3 ? color.new(color.lime, 40) : color.gray
    table.cell(dash, 0, 1, "CLOCK 1: MARKET",    text_color=color.aqua,   text_size=size.tiny)
    table.cell(dash, 1, 1, "",                   text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 0, 2, "Volatility State",   text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 2, c1_str,              text_color=c1_col,       text_size=size.tiny)
    table.cell(dash, 0, 3, "ATR Ratio",          text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 3, str.tostring(atr_ratio, "#.##") + "  (thr: " + str.tostring(i_compress) + ")", text_color=compressed ? color.yellow : color.white, text_size=size.tiny)
    table.cell(dash, 0, 4, "BB Squeeze",         text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 4, bb_squeeze ? "YES - Bands tight" : "NO", text_color=bb_squeeze ? color.yellow : color.gray, text_size=size.tiny)

    // Clock 2
    s_str = london_open ? "LONDON OPEN" : ny_open ? "NY OPEN" : "OFF-SESSION"
    s_col = in_session ? color.lime : color.gray
    table.cell(dash, 0, 5, "CLOCK 2: SESSION",   text_color=color.aqua,   text_size=size.tiny)
    table.cell(dash, 1, 5, "",                   text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 0, 6, "Current Window",     text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 6, s_str,               text_color=s_col,        text_size=size.small)
    table.cell(dash, 0, 7, "Trade Here?",        text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 7, in_session ? "YES" : "WAIT", text_color=in_session ? color.lime : color.red, text_size=size.small)

    // Clock 3
    f_str = fakeout_bear ? "BEARISH FAKEOUT" : fakeout_bull ? "BULLISH FAKEOUT" : "No fake detected"
    f_col = fakeout_bear ? color.red : fakeout_bull ? color.lime : color.gray
    table.cell(dash, 0, 8,  "CLOCK 3: FAKEOUT",  text_color=color.aqua,   text_size=size.tiny)
    table.cell(dash, 1, 8,  "",                  text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 0, 9,  "Signal This Bar",   text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 9,  f_str,              text_color=f_col,        text_size=size.small)
    table.cell(dash, 0, 10, "Range High",        text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 10, str.tostring(range_high, format.mintick), text_color=color.red,  text_size=size.tiny)
    table.cell(dash, 0, 11, "Range Low",         text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 11, str.tostring(range_low,  format.mintick), text_color=color.lime, text_size=size.tiny)

    // EV Score
    ev_now   = math.max(ev_bear, ev_bull)
    ev_dir   = ev_bear > ev_bull ? "SHORT (FADE)" : ev_bull > ev_bear ? "LONG (FADE)" : "--"
    ev_col   = ev_now == 3 ? color.lime : ev_now == 2 ? color.yellow : color.gray
    table.cell(dash, 0, 12, "EV SCORE",          text_color=color.white,  text_size=size.small)
    table.cell(dash, 1, 12, str.tostring(ev_now) + " / 3", text_color=ev_col, text_size=size.large)
    table.cell(dash, 0, 13, "DIRECTION",         text_color=color.white,  text_size=size.small)
    table.cell(dash, 1, 13, ev_dir,             text_color=ev_col,        text_size=size.normal)
    table.cell(dash, 0, 14, "R : R",             text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 14, "1 : " + str.tostring(math.round(i_tp_atr / i_sl_atr, 1)), text_color=color.white, text_size=size.small)

    // Status
    status_str = signal_bear ? "ACTIVE SHORT SIGNAL" : signal_bull ? "ACTIVE LONG SIGNAL" : "WAITING..."
    status_col = signal_bear ? color.red : signal_bull ? color.lime : color.gray
    table.cell(dash, 0, 15, "STATUS",   text_color=color.white, text_size=size.tiny)
    table.cell(dash, 1, 15, status_str, text_color=status_col,  text_size=size.small)

// ────────────────────────────────────────────────────────────
//  ALERT CONDITIONS
// ────────────────────────────────────────────────────────────

alertcondition(signal_bull, title="3C-Edge: LONG Signal (Fade Breakdown)", message="3C EDGE - FADE LONG on {{ticker}} ({{interval}}) | Bullish Fakeout below range low | Check EV score")
alertcondition(signal_bear, title="3C-Edge: SHORT Signal (Fade Breakout)", message="3C EDGE - FADE SHORT on {{ticker}} ({{interval}}) | Bearish Fakeout above range high | Check EV score")
alertcondition(compressed,  title="3C-Edge: Market Coiling (Clock 1)",     message="3C EDGE - Volatility COMPRESSING on {{ticker}} | Spring loading - prepare for expansion")
alertcondition(just_expanded, title="3C-Edge: Volatility Expanding Now",   message="3C EDGE - Volatility EXPANDING on {{ticker}} | Post-compression move beginning!")
alertcondition(signal_bull and ev_bull == 3, title="3C-Edge: PERFECT LONG (3/3 Clocks)", message="3C EDGE - MAX EV LONG on {{ticker}} | All 3 Clocks aligned! Highest conviction setup.")
alertcondition(signal_bear and ev_bear == 3, title="3C-Edge: PERFECT SHORT (3/3 Clocks)", message="3C EDGE - MAX EV SHORT on {{ticker}} | All 3 Clocks aligned! Highest conviction setup.")
